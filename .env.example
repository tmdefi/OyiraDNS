# Service
NODE_ENV=development
PORT=3000
SERVICE_NAME=domain-purchasing-mcp
# Public Oyira ASP base URL for Claude/MCP wrappers and marketplace docs.
OYIRA_BASE_URL=https://asp.oyiradns.xyz

# Persistent storage
# Use a Supabase Postgres connection string in Railway to keep quotes, x402 purchases, ledger, and audit logs across deploys.
# Prefer the pooled connection string from Supabase for serverless/managed deploys.
SUPABASE_DB_URL=
DATABASE_SSL=true

# Gemini AI
# GOOGLE_API_KEY takes precedence over GEMINI_API_KEY when both are set.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Dynadot API
DYNADOT_API_VERSION=v2
DYNADOT_ENV=sandbox
DYNADOT_LIVE_API_BASE_URL=https://api.dynadot.com
DYNADOT_LIVE_API_KEY=
DYNADOT_LIVE_API_SECRET=
DYNADOT_SANDBOX_API_BASE_URL=https://api-sandbox.dynadot.com
DYNADOT_SANDBOX_API_KEY=
DYNADOT_SANDBOX_API_SECRET=
ALLOW_LIVE_PURCHASES=false
ALLOW_DOMAIN_PUSHES=false
ALLOW_DNS_CHANGES=false
ALLOW_NAMESERVER_CHANGES=false

# OKX Payment SDK
OKX_BASE_URL=https://www.okx.com
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_PROJECT_ID=
OKX_PAYMENT_SYMBOL=USDC
OKX_PAYMENT_REALM=
OKX_PAYMENT_CREATE_PATH=/api/v6/pay/a2a/payment/create
OKX_PAYMENT_STATUS_PATH=/api/v6/pay/a2a/p/{paymentId}/status
OKX_REQUIRED_PAYMENT_STATUS=completed
OKX_WALLET_ADDRESS=
OKX_NETWORK=
OKX_SETTLEMENT_ASSET=
OKX_TEST_PAYMENT_AMOUNT=0.01

# x402 domain purchase endpoint
X402_ENABLED=true
X402_NETWORK=eip155:196
X402_PAY_TO=
X402_TEST_PAYMENT_AMOUNT=0.01
X402_MAX_TIMEOUT_SECONDS=300
X402_SYNC_SETTLE=false
X402_PURCHASE_STORE_PATH=data/x402-domain-purchases.json
X402_TEST_PAYMENT_URL=https://asp.oyiradns.xyz/x402/test-payment
# Local payer key for src/scripts/x402-test-payment.ts. Use a fresh low-balance test wallet only.
X402_PAYER_PRIVATE_KEY=
X402_DOMAIN_PURCHASE_URL=https://asp.oyiradns.xyz/x402/domain/purchase
X402_PURCHASE_DOMAIN=
X402_PURCHASE_YEARS=1
X402_PURCHASE_IDEMPOTENCY_KEY=
X402_PURCHASE_NAMESERVERS=
X402_REGISTRANT_NAME=
X402_REGISTRANT_EMAIL=
# Include the phone country code in X402_REGISTRANT_PHONE, or set X402_REGISTRANT_PHONE_CC separately.
# Example 1: X402_REGISTRANT_PHONE=+14155550100
# Example 2: X402_REGISTRANT_PHONE=4155550100 and X402_REGISTRANT_PHONE_CC=1
X402_REGISTRANT_PHONE=
# Phone country calling code only, without +. Example: 1 for US/Canada, 44 for UK, 234 for Nigeria.
X402_REGISTRANT_PHONE_CC=
X402_REGISTRANT_ADDRESS=
X402_REGISTRANT_CITY=
X402_REGISTRANT_COUNTRY=
X402_REGISTRANT_STATE=
X402_REGISTRANT_POSTAL_CODE=
X402_REGISTRANT_ORGANIZATION=

# Pricing
SERVICE_FEE_AMOUNT=
SERVICE_FEE_CURRENCY=USD

# Domain Quotes
QUOTE_STORE_PATH=data/domain-quotes.json
QUOTE_TTL_SECONDS=1500
QUOTE_DEFAULT_CURRENCY=USD
QUOTE_PAYMENT_SYMBOL=USDC
QUOTE_SERVICE_FEE_AMOUNT=0
DOMAIN_SEARCH_DEFAULT_TLDS=com,xyz,net,org,io,co

# Security
API_AUTH_TOKEN=
# Comma-separated user keys: customerId:token or customerId:token:keyId
# Example: alice:oyira_user_token_1:alice-main,bob:oyira_user_token_2:bob-main
OYIRA_USER_API_KEYS=
# Automatic user signup/key issuing
OYIRA_PUBLIC_SIGNUP_ENABLED=false
OYIRA_USER_API_KEY_STORE_PATH=data/oyira-user-api-keys.json

# Domain Monitoring
MONITOR_STORE_PATH=data/domain-monitors.json
MONITOR_DEFAULT_CURRENCY=USD
MONITOR_INTERVAL_SECONDS=300

# Domain Ownership Ledger
DOMAIN_LEDGER_STORE_PATH=data/domain-ledger.json

# Oyira Sessions
OYIRA_SESSION_STORE_PATH=data/oyira-sessions.json

# Oyira Audit Log
OYIRA_AUDIT_LOG_PATH=data/oyira-audit.jsonl
