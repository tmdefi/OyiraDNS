# Service
NODE_ENV=development
PORT=3000
SERVICE_NAME=domain-purchasing-mcp

# Gemini AI
# GOOGLE_API_KEY takes precedence over GEMINI_API_KEY when both are set.
GEMINI_API_KEY=
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Dynadot API
DYNADOT_API_VERSION=v2
DYNADOT_ENV=sandbox
DYNADOT_LIVE_API_BASE_URL=https://api.dynadot.com
DYNADOT_LIVE_API_KEY=
DYNADOT_LIVE_API_SECRET=
DYNADOT_SANDBOX_API_BASE_URL=https://api-sandbox.dynadot.com
DYNADOT_SANDBOX_API_KEY=
DYNADOT_SANDBOX_API_SECRET=
ALLOW_LIVE_PURCHASES=false
ALLOW_DOMAIN_PUSHES=false
ALLOW_DNS_CHANGES=false
ALLOW_NAMESERVER_CHANGES=false

# OKX Payment SDK
OKX_BASE_URL=https://www.okx.com
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=
OKX_PROJECT_ID=
OKX_PAYMENT_SYMBOL=USDC
OKX_PAYMENT_REALM=
OKX_PAYMENT_CREATE_PATH=/api/v6/pay/a2a/payment/create
OKX_PAYMENT_STATUS_PATH=/api/v6/pay/a2a/p/{paymentId}/status
OKX_REQUIRED_PAYMENT_STATUS=completed
OKX_WALLET_ADDRESS=
OKX_NETWORK=
OKX_SETTLEMENT_ASSET=
OKX_TEST_PAYMENT_AMOUNT=0.01

# x402 domain purchase endpoint
X402_ENABLED=true
X402_NETWORK=eip155:196
X402_PAY_TO=
X402_MAX_TIMEOUT_SECONDS=300
X402_SYNC_SETTLE=false
X402_PURCHASE_STORE_PATH=data/x402-domain-purchases.json

# Pricing
SERVICE_FEE_AMOUNT=
SERVICE_FEE_CURRENCY=USD

# Domain Quotes
QUOTE_STORE_PATH=data/domain-quotes.json
QUOTE_TTL_SECONDS=900
QUOTE_DEFAULT_CURRENCY=USD
QUOTE_PAYMENT_SYMBOL=USDC
QUOTE_SERVICE_FEE_AMOUNT=0
DOMAIN_SEARCH_DEFAULT_TLDS=com,xyz,net,org,io,co,app,dev

# Security
API_AUTH_TOKEN=
# Comma-separated user keys: customerId:token or customerId:token:keyId
# Example: alice:oyira_user_token_1:alice-main,bob:oyira_user_token_2:bob-main
OYIRA_USER_API_KEYS=
# Automatic user signup/key issuing
OYIRA_PUBLIC_SIGNUP_ENABLED=true
OYIRA_USER_API_KEY_STORE_PATH=data/oyira-user-api-keys.json

# Domain Monitoring
MONITOR_STORE_PATH=data/domain-monitors.json
MONITOR_DEFAULT_CURRENCY=USD
MONITOR_INTERVAL_SECONDS=300

# Domain Ownership Ledger
DOMAIN_LEDGER_STORE_PATH=data/domain-ledger.json

# Oyira Sessions
OYIRA_SESSION_STORE_PATH=data/oyira-sessions.json

# Oyira Audit Log
OYIRA_AUDIT_LOG_PATH=data/oyira-audit.jsonl
